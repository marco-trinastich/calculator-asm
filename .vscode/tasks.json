{
    // These tasks invoke exactly the same `make` you would run from the console.
    // Host tooling (native compiler for AMD64/x86/ARM64 host) is auto-detected by
    // scripts/components/vsexec.bat via vswhere -> vcvarsall. Target is always x64.
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "rebuild",
            "dependsOrder": "sequence",
            "dependsOn": [
                "clean",
                "build"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ]
}
